{
  "openapi": "3.0.1",
  "info": {
    "title": "Профессия 2.0 API",
    "version": "1.0.0",
    "description": "REST API for Профессия 2.0 — Цифровой кадровый резерв"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local"
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login user",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/courses": {
      "get": {
        "summary": "List courses",
        "parameters": [
          {
            "name": "skill",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "summary": "Create course",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/courses/{id}": {
      "get": {
        "summary": "Get course detail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/courses/{id}/lessons": {
      "get": {
        "summary": "List lessons",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/quiz/{courseId}/start": {
      "post": {
        "summary": "Start adaptive quiz",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/quiz/{courseId}/answer": {
      "post": {
        "summary": "Answer quiz question",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/quiz/{courseId}/finish": {
      "post": {
        "summary": "Finish quiz",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/jobs": {
      "get": {
        "summary": "List jobs",
        "parameters": [
          {
            "name": "matchFor",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "summary": "Create job",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/jobs/{id}/apply": {
      "post": {
        "summary": "Apply to job",
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/jobs/me/applications": {
      "get": {
        "summary": "My applications",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/mentors": {
      "get": {
        "summary": "List mentors",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/portfolio/me": {
      "get": {
        "summary": "My portfolio",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "put": {
        "summary": "Update portfolio",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/portfolio/public/{id}": {
      "get": {
        "summary": "Public profile",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/badges/me": {
      "get": {
        "summary": "My badges",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["student", "employer"]
          }
        }
      }
    }
  }
}
