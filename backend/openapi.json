{
  "openapi": "3.0.3",
  "info": {
    "title": "Профессия 2.0 API",
    "version": "1.0.0"
  },
  "paths": {
    "/auth/register": {
      "post": {
        "summary": "Register user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Registered" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": { "200": { "description": "Logged" } }
      }
    },
    "/courses": {
      "get": {
        "summary": "List courses",
        "parameters": [
          {
            "name": "skill",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/courses/{id}": {
      "get": {
        "summary": "Get course",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/courses/{id}/lessons": {
      "get": {
        "summary": "Course lessons",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/quiz/{courseId}/start": {
      "post": {
        "summary": "Start quiz",
        "parameters": [
          { "name": "courseId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/quiz/{courseId}/answer": {
      "post": {
        "summary": "Answer quiz question",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/quiz/{courseId}/finish": {
      "post": {
        "summary": "Finish quiz",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/me/badges": {
      "get": { "summary": "My badges", "responses": { "200": { "description": "OK" } } }
    },
    "/me/portfolio": {
      "post": { "summary": "Update portfolio link", "responses": { "200": { "description": "OK" } } }
    },
    "/badge/{id}/qrcode": {
      "get": { "summary": "Badge QR", "responses": { "200": { "description": "OK" } } }
    },
    "/u/{id}": {
      "get": {
        "summary": "Public learner profile",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/jobs": {
      "get": {
        "summary": "List jobs",
        "parameters": [
          { "name": "city", "in": "query", "schema": { "type": "string" } },
          { "name": "skills", "in": "query", "schema": { "type": "string" } },
          { "name": "matchFor", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      },
      "post": { "summary": "Create job", "responses": { "201": { "description": "Created" } } }
    },
    "/jobs/{id}/apply": {
      "post": { "summary": "Apply job", "responses": { "201": { "description": "Created" } } }
    },
    "/mentors": {
      "get": { "summary": "List mentors", "responses": { "200": { "description": "OK" } } }
    },
    "/admin/courses": {
      "get": { "summary": "Admin courses", "responses": { "200": { "description": "OK" } } },
      "post": { "summary": "Create course", "responses": { "201": { "description": "Created" } } }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" }
        },
        "required": ["email", "password", "name"]
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      }
    }
  }
}
